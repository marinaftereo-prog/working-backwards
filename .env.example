# The backend reads its key from server/.env.
# This root copy is here for convenience — copy it to server/.env and fill it in.
#
#   cp .env.example server/.env
#
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — the Express server's port (defaults to 3001)
PORT=3001

# Optional — protect the whole app with a shared password (HTTP Basic Auth).
# Great for a private friends & family beta. Leave unset to make the app open.
# Anyone visiting will be asked for a password; the username can be anything.
# ACCESS_PASSWORD=our-secret-word

# Optional — max generation requests per IP per 30 minutes (defaults to 30).
# One full run = 3 requests, so 30 ≈ 10 runs per person. Guards your API spend.
# RATE_LIMIT_MAX=30
